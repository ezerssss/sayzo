rules_version = '2';

// All writes go through the Firebase Admin SDK on the server, which bypasses
// these rules. The client — admin OR non-admin — never writes Firestore
// directly, so every `allow write` here is `false`. Any state change must
// hit a server route, which validates input, audit-logs, and uses the
// Admin SDK to mutate.
//
// Reads: non-admin owners can read their own data via the client SDK
// (existing webapp pattern). Admins additionally bypass per-collection read
// rules so the admin dashboard can use Firestore listeners across users.
// The `isAdmin()` flag is also enforced server-side in `requireAdmin()` —
// defense in depth.

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helpers
    // ----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ----------------------------------------------------------------
    // Client-readable: owner-only (admin reads also pass)
    // ----------------------------------------------------------------

    // Profile, onboarding state, credits. Doc id is the user's uid.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // Aggregated coaching view per user. Doc id is the user's uid.
    match /user-focus-insights/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // Capture-replay sessions (legacy drill docs may remain). Owner identified by `uid` field.
    // Client queries always include `where("uid", "==", auth.uid)`.
    match /sessions/{sessionId} {
      allow read: if ownsResource() || isAdmin();
      allow write: if false;
    }

    // Captured real-conversation records. Owner identified by `uid` field.
    match /captures/{captureId} {
      allow read: if ownsResource() || isAdmin();
      allow write: if false;
    }

    // User reactions (thumbs up/down + optional reason) on coaching output.
    // Owner identified by `uid` field — owner reads their own to render current
    // state; admin reads all for monitoring. Server (Admin SDK) is the only
    // writer, via POST /api/reactions.
    match /item_reactions/{reactionId} {
      allow read: if ownsResource() || isAdmin();
      allow write: if false;
    }

    // ----------------------------------------------------------------
    // Server-only collections — admin can read, no one writes from client
    // ----------------------------------------------------------------

    // Merged learner model: skills/habits + prose coaching context. Server-only
    // (admin read, no client write) — this closes the leak where the prose
    // context used to live on the owner-readable users doc. (user-focus-insights
    // intentionally stays its own owner-readable collection.)
    match /learner-models/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // OAuth / PKCE auth flow for the desktop companion login.
    match /auth_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /auth_codes/{code} {
      allow read: if isAdmin();
      allow write: if false;
    }
    // Stored as SHA-256 hashes; admin can read for cascade-delete cleanup.
    match /refresh_tokens/{tokenHash} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Admin queues / cross-user submissions.
    match /access_requests/{requestId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /support_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /support_reports_rate/{key} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Append-only audit log for admin actions. Reads are admin-only; writes
    // go through the server (Admin SDK) so the rule denial here keeps the
    // log tamper-evident from any client.
    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Desktop-companion diagnostic logs (device OS, app version, install id,
    // error logs — PII/content-free, no meeting audio/transcripts). Admin read
    // for the dashboard; the Admin SDK is the only writer.
    match /diagnostic_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Per-call LLM/ASR/TTS telemetry + quality enums + prompt-version hash + id
    // refs. Content-free (no transcript, no error.message). Admin read; the
    // Admin SDK is the only writer (fire-and-forget from the analysis pipeline).
    match /llm_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Daily pre-aggregated metric counters over llm_events. Admin read; written
    // by the rollup cron via the Admin SDK only.
    match /metric_rollups/{rollupId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // In-app admin alerts (threshold trips). Admin read; written by the rollup
    // cron / admin ack-resolve routes via the Admin SDK only.
    match /admin_alerts/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ----------------------------------------------------------------
    // Default deny: anything not explicitly allowed above is closed.
    // ----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
