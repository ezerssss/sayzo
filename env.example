NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional (server-only): overrides the bucket name used by Firebase Admin uploads.
# Usually this is your default bucket: <project-id>.appspot.com
FIREBASE_STORAGE_BUCKET=

# Firebase Admin SDK (server only — never expose in client code)
# Create a key: Firebase Console → Project settings → Service accounts → Generate new private key.
# Option A (deployments): paste the entire JSON file contents as ONE line below (minify first if needed).
# Option B (local): download the JSON, keep it outside the repo, and set:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-project-firebase-adminsdk-xxxxx.json
#   (leave FIREBASE_SERVICE_ACCOUNT_JSON empty when using Option B)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Secret for signing OAuth access-token JWTs (server only).
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

OPENAI_API_KEY=

# Hume AI — Expression Measurement (batch: prosody + burst on audio, language on transcript)
# https://platform.hume.ai/settings/keys
HUME_API_KEY=

# Optional: OpenAI chat model for session analyzer (defaults to gpt-4o-mini)
ANALYZER_MODEL=

# Optional: model for profile context builder (defaults to ANALYZER_MODEL, then gpt-4o-mini)
PROFILE_BUILDER_MODEL=

# Optional: model for planner role (defaults to ANALYZER_MODEL, then gpt-4o-mini)
PLANNER_MODEL=

# Capture processing pipeline (server-side re-transcription and analysis of real conversations)
# Secret for authenticating the cron job that triggers capture processing.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Optional: STT model for capture re-transcription (defaults to whisper-1)
CAPTURE_TRANSCRIBE_MODEL=

# Optional: LLM model for capture analysis and profiling (defaults to ANALYZER_MODEL, then gpt-4o-mini)
CAPTURE_ANALYZER_MODEL=