NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (server only — never expose in client code)
# Create a key: Firebase Console → Project settings → Service accounts → Generate new private key.
# Option A (deployments): paste the entire JSON file contents as ONE line below (minify first if needed).
# Option B (local): download the JSON, keep it outside the repo, and set:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-project-firebase-adminsdk-xxxxx.json
#   (leave FIREBASE_SERVICE_ACCOUNT_JSON empty when using Option B)
FIREBASE_SERVICE_ACCOUNT_JSON=

OPENAI_API_KEY=